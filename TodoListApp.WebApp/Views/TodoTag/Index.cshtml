@model IEnumerable<TodoListApp.WebApp.Models.TodoTagModel>
@{
    ViewData["Title"] = "Manage Tags";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark"><i class="bi bi-tags me-2 text-primary"></i>Manage Tags</h2>
</div>

<div class="card mb-4 border-2 frame-primary">
    <div class="card-body p-4">
        <h5 class="fw-bold text-dark mb-3">Create New Tag</h5>
        <form asp-action="Create" method="post" class="d-flex gap-2 align-items-center" style="max-width: 400px;">
            <div class="input-group">
                <span class="input-group-text bg-white border-2 border-primary text-primary fw-bold"><i class="bi bi-hash"></i></span>
                <input type="text" name="Name" class="form-control border-2 border-primary fw-bold text-dark bg-white" placeholder="e.g. urgent, backend" required autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-positive"><i class="bi bi-plus-lg"></i> Add</button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm p-4">
    <h5 class="fw-bold text-dark mb-4"><i class="bi bi-collection me-2"></i>All Tags</h5>

    @if (!Model.Any())
    {
        <div class="alert alert-warning border-2 fw-bold"><i class="bi bi-info-circle me-2"></i>No tags found. Create your first one above!</div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2">
            @foreach (var tag in Model.OrderBy(t => t.Name))
            {
                <div class="tag-pill tag-pill-lg d-flex align-items-center shadow-sm">
                    <i class="bi bi-hash me-1 opacity-75"></i>@tag.Name

                    <button type="button" class="btn-close btn-close-white ms-3" style="font-size: 0.65rem;" data-bs-toggle="modal" data-bs-target="#deleteTagModal-@tag.Id" aria-label="Remove"></button>

                    <partial name="_DeleteModal" model="@(($"deleteTagModal-{tag.Id}", tag.Name, "Tag", "Are you sure you want to delete this tag? It will be removed from all associated tasks!", Url.Action("Delete", "TodoTag"), "id", tag.Id, "", ""))" />
                </div>
            }
        </div>
    }
</div>