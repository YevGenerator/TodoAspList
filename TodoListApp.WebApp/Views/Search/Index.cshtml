@model TodoListApp.WebApp.Models.SearchResultModel
@{
    ViewData["Title"] = "Search Results";
}

<h2 class="fw-bold text-dark mb-4"><i class="bi bi-search me-2"></i>Search Results for "@Model.SearchQuery"</h2>

<div class="row">
    <div class="col-md-6 mb-4">
        <h4 class="fw-bold text-dark mb-3"><i class="bi bi-list-task me-2"></i>To-Do Lists</h4>
        <div class="list-group border-2">
            @if (!Model.TodoLists.Any())
            {
                <div class="list-group-item text-muted fw-bold">No lists found.</div>
            }
            else
            {
                @foreach (var list in Model.TodoLists)
                {
                    <a asp-controller="TodoList" asp-action="Index" class="list-group-item list-group-item-action task-row fw-bold text-dark p-3">
                        <span class="fs-5">@list.Title</span>
                        <p class="mb-0 mt-1 text-muted">@list.Description</p>
                    </a>
                }
            }
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <h4 class="fw-bold text-dark mb-3"><i class="bi bi-check2-square me-2"></i>Tasks</h4>
        <div class="list-group border-2">
            @if (!Model.TodoTasks.Any())
            {
                <div class="list-group-item text-muted fw-bold">No tasks found.</div>
            }
            else
            {
                @foreach (var task in Model.TodoTasks)
                {
                    <div class="list-group-item task-row p-3" onclick="window.location.href='@Url.Action("Details", "TodoTask", new { id = task.Id })'">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold text-dark fs-5">@task.Title</span>
                            <span class="badge bg-white border border-2 px-2 status-@task.Status.ToString()">@task.Status</span>
                        </div>
                        <small class="text-muted fw-bold"><i class="bi bi-calendar me-1"></i>@(task.DueDate?.ToShortDateString() ?? "No date")</small>
                    </div>
                }
            }
        </div>
    </div>
</div>