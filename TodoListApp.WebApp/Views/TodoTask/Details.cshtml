@model TodoListApp.WebApp.Models.TodoTaskModel

@{
    ViewData["Title"] = "Task Details";
}

<h2>Task Details</h2>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9 fw-bold">@Model.Title</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Due Date</dt>
        <dd class="col-sm-9">@(Model.DueDate.HasValue? Model.DueDate.Value.ToShortDateString() : "Not set")</dd>

        <dt class="col-sm-3">Assignee</dt>
        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Assignee) ? "Unassigned" : Model.Assignee)</dd>
    </dl>
</div>
<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">Edit Task</a>
    <a asp-action="Index" asp-route-todoListId="@Model.TodoListId" class="btn btn-secondary">Back to Tasks</a>
</div>