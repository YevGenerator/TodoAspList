@model TodoListApp.WebApp.Models.TodoTaskModel

@{
    ViewData["Title"] = "Task Details";
    var availableTags = ViewBag.AvailableTags as List<TodoListApp.WebApp.Models.TodoTagModel> ?? new List<TodoListApp.WebApp.Models.TodoTagModel>();
}

<h2>Task Details</h2>
<hr />
<div class="row">
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9 fw-bold">@Model.Title</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Status == TodoListApp.Models.Enums.TodoTaskStatus.Completed ? "bg-success" : "bg-secondary")">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@(Model.DueDate.HasValue? Model.DueDate.Value.ToShortDateString() : "Not set")</dd>

            <dt class="col-sm-3">Assignee</dt>
            <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Assignee) ? "Unassigned" : Model.Assignee)</dd>

            <dt class="col-sm-3 mt-3">Tags</dt>
            <dd class="col-sm-9 mt-3">
                @if (!Model.Tags.Any())
                {
                    <span class="text-muted">No tags assigned.</span>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="badge bg-info text-dark d-flex align-items-center">
                                @tag.Name
                                <form asp-action="RemoveTag" method="post" class="ms-2 mb-0">
                                    <input type="hidden" name="taskId" value="@Model.Id" />
                                    <input type="hidden" name="tagId" value="@tag.Id" />
                                    <button type="submit" class="btn-close btn-close-white" style="font-size: 0.5rem;" aria-label="Remove"></button>
                                </form>
                            </span>
                        }
                    </div>
                }

                @if (availableTags.Any())
                {
                    <form asp-action="AssignTag" method="post" class="d-flex mt-3" style="max-width: 300px;">
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <select name="tagId" class="form-select form-select-sm me-2" required>
                            <option value="">-- Select Tag to Add --</option>
                            @foreach (var tag in availableTags)
                            {
                                <option value="@tag.Id">@tag.Name</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-outline-primary">Add</button>
                    </form>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">Edit Task</a>
    <a asp-action="Index" asp-route-todoListId="@Model.TodoListId" class="btn btn-secondary">Back to Tasks</a>
</div>

<hr class="mt-5" />
<div class="row">
    <div class="col-md-8">
        <h4>Comments</h4>

        <div class="card mb-4">
            <div class="card-body">
                <form asp-controller="TodoTaskComment" asp-action="Create" method="post">
                    <input type="hidden" name="TodoTaskId" value="@Model.Id" />
                    <div class="form-group mb-2">
                        <textarea name="Text" class="form-control" rows="2" placeholder="Write a comment..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Post Comment</button>
                </form>
            </div>
        </div>

        @if (!Model.Comments.Any())
        {
            <p class="text-muted">No comments yet.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var comment in Model.Comments)
                {
                    <div class="list-group-item">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1 fw-bold">@comment.CreatedBy</h6>
                            <small class="text-muted">@comment.CreatedAt.ToLocalTime().ToString("g")</small>
                        </div>
                        <p class="mb-1 mt-2">@comment.Text</p>

                        <div class="mt-2 text-end">
                            <form asp-controller="TodoTaskComment" asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this comment?');">
                                <input type="hidden" name="id" value="@comment.Id" />
                                <input type="hidden" name="taskId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-link text-danger p-0 border-0">Delete</button>
                            </form>
                            <span class="text-muted mx-1">|</span>
                            <a asp-controller="TodoTaskComment" asp-action="Edit" asp-route-id="@comment.Id" class="btn btn-sm btn-link text-warning p-0 border-0">Edit</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>