@model IEnumerable<TodoListApp.WebApp.Models.TodoTaskModel>
@using TodoListApp.Models.Enums

@{
    ViewData["Title"] = "Assigned Tasks";
    string currentAssignee = ViewBag.Assignee as string ?? "";
    TodoTaskStatus? currentStatus = ViewBag.CurrentStatus as TodoTaskStatus?;
    string currentSort = ViewBag.CurrentSort as string ?? "";
}

<h2>Assigned Tasks</h2>
<hr />

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Assigned" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="assignee" class="form-label fw-bold">Assignee Name (Required)</label>
                <input type="text" id="assignee" name="assignee" class="form-control" value="@currentAssignee" placeholder="e.g. John Doe" required />
            </div>
            <div class="col-md-3">
                <label for="status" class="form-label fw-bold">Status Filter</label>
                <select id="status" name="status" class="form-select">
                    <option value="">Active (Not Started & In Progress)</option>
                    @foreach (var status in Enum.GetValues(typeof(TodoTaskStatus)))
                    {
                        if (currentStatus.HasValue && currentStatus.Value.Equals(status))
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="sortBy" class="form-label fw-bold">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(currentSort))">Created Date (Default)</option>
                    <option value="title" selected="@(currentSort == "title")">Title</option>
                    <option value="duedate" selected="@(currentSort == "duedate")">Due Date</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
        </form>
    </div>
</div>

@if (string.IsNullOrWhiteSpace(currentAssignee))
{
    <div class="alert alert-info">Please enter an assignee name to view tasks.</div>
}
else if (!Model.Any())
{
    <div class="alert alert-warning">No tasks found for "@currentAssignee" with the current filters.</div>
}
else
{
    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Quick Status Update</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                bool isOverdue = item.DueDate.HasValue
                && item.DueDate.Value.Date < DateTime.Today
                && item.Status != TodoTaskStatus.Completed;

                <tr class="@(isOverdue ? "table-danger" : "")">
                    <td class="align-middle fw-bold">
                        @if (isOverdue)
                        {
                            <span class="badge bg-danger me-1">Overdue</span>
                        }
                        @item.Title
                    </td>
                    <td class="align-middle">@(item.DueDate.HasValue? item.DueDate.Value.ToShortDateString() : "-")</td>
                    <td class="align-middle">
                        <span class="badge @(item.Status == TodoTaskStatus.Completed ? "bg-success" : (item.Status == TodoTaskStatus.InProgress ? "bg-warning text-dark" : "bg-secondary"))">
                            @item.Status
                        </span>
                    </td>
                    <td class="align-middle">
                        <form asp-action="ChangeStatus" method="post" class="d-flex">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="assignee" value="@currentAssignee" />
                            <input type="hidden" name="currentStatus" value="@currentStatus" />
                            <input type="hidden" name="currentSort" value="@currentSort" />

                            <select name="newStatus" class="form-select form-select-sm me-2" style="width: auto;">
                                @foreach (TodoTaskStatus status in Enum.GetValues(typeof(TodoTaskStatus)))
                                {
                                    <option value="@status" selected="@(item.Status == status)">@status</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}