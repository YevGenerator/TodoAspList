@model IEnumerable<TodoListApp.WebApp.Models.TodoTaskModel>
@using TodoListApp.Models.Enums
@{
    ViewData["Title"] = "Task Explorer";
    string currentAssignee = ViewBag.Assignee as string ?? "";
    string tagSearch = ViewBag.TagSearch as string ?? "";
    TodoTaskStatus? currentStatus = ViewBag.CurrentStatus as TodoTaskStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark"><i class="bi bi-search me-2 text-primary"></i>Task Explorer</h2>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Assigned" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="assignee" class="form-label fw-bold text-dark small"><i class="bi bi-person me-1"></i>Assignee</label>
                <input type="text" id="assignee" name="assignee" class="form-control form-control-sm border-2 fw-bold text-dark" value="@currentAssignee" placeholder="Leave empty for all" />
            </div>
            <div class="col-md-4 position-relative">
                <label for="tagSearch" class="form-label fw-bold text-dark small"><i class="bi bi-tags me-1"></i>Tags (+must, -exclude)</label>
                <input type="text" id="tagSearch" name="tagSearch" class="form-control form-control-sm border-2 fw-bold text-dark" value="@tagSearch" placeholder="+urgent -work" autocomplete="off" />
                <div id="tagSuggestions" class="list-group position-absolute w-100 border-2" style="z-index: 1000; display: none; top: 100%;"></div>
            </div>
            <div class="col-md-3">
                <label for="status" class="form-label fw-bold text-dark small"><i class="bi bi-flag me-1"></i>Status</label>
                <select id="status" name="status" class="form-select form-select-sm border-2 fw-bold text-dark">
                    <option value="">All Active</option>
                    @foreach (var stat in Enum.GetValues(typeof(TodoTaskStatus)))
                    {
                        <option value="@stat" selected="@(currentStatus.HasValue && currentStatus.Value.Equals(stat))">@stat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-neutral btn-sm w-100"><i class="bi bi-filter"></i> Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="list-group bg-transparent">
    @if (!Model.Any())
    {
        <div class="alert alert-warning border-2 fw-bold"><i class="bi bi-emoji-frown me-2"></i>No tasks found matching your criteria.</div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <partial name="_TaskCard" model="@((item, "", currentAssignee, Context.Request.Path + Context.Request.QueryString, true, false))" />
        }
    }
</div>

@section Scripts {
    <script>window.allTags = @Html.Raw(Json.Serialize(ViewBag.AllTags ?? new List<string>()));</script>
    @{
        await Html.RenderPartialAsync("_TagAutocomplete");
    }
}