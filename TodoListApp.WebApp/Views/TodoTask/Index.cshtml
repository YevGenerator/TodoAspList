@model IEnumerable<TodoListApp.WebApp.Models.TodoTaskModel>
@{
    ViewData["Title"] = "List Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark"><i class="bi bi-card-checklist me-2 text-primary"></i>List Tasks</h2>
    <div class="d-flex gap-2">
        <!-- //NOSONAR --><a asp-action="Create" asp-route-todoListId="@ViewBag.TodoListId" class="btn btn-positive"><i class="bi bi-plus-lg"></i> Add Task</a>
        <!-- //NOSONAR --><a asp-controller="TodoList" asp-action="Index" class="btn btn-negative"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="card p-4 bg-transparent border-0 shadow-none">
    @if (!Model.Any())
    {
        <div class="alert alert-warning border-2 fw-bold"><i class="bi bi-emoji-frown me-2"></i>This list is empty.</div>
    }
    else
    {
        <div class="list-group bg-transparent">
            @foreach (var item in Model)
            {
                <partial name="_TaskCard" model="@((item, "", User.Identity?.Name ?? "", Context.Request.Path + Context.Request.QueryString, true, true))" />
            }
        </div>
    }
</div>