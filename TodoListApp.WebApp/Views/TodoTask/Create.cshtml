@model TodoListApp.WebApp.Models.TodoTaskModel
@using TodoListApp.Models.Enums
@{
    ViewData["Title"] = "Add Task";
}

<h2 class="fw-bold text-dark mb-4"><i class="bi bi-plus-square text-success me-2"></i>Add New Task</h2>
<div class="card border-0 shadow-sm p-4 col-md-8">
    <form asp-action="Create">
        <input type="hidden" asp-for="TodoListId" />
        <div class="form-group mb-3">
            <!-- //NOSONAR --><label asp-for="Title" class="form-label fw-bold text-dark"></label>
            <input asp-for="Title" class="form-control border-2 fw-bold text-dark bg-light" />
            <span asp-validation-for="Title" class="text-danger fw-bold"></span>
        </div>
        <div class="form-group mb-3">
            <!-- //NOSONAR --><label asp-for="Description" class="form-label fw-bold text-dark"></label>
            <textarea asp-for="Description" class="form-control border-2 fw-bold text-dark bg-light" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger fw-bold"></span>
        </div>
        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <!-- //NOSONAR --><label asp-for="DueDate" class="form-label fw-bold text-dark"></label>
                <input asp-for="DueDate" class="form-control border-2 fw-bold text-dark bg-light" />
            </div>
            <div class="col-md-6 form-group mb-3">
                <!-- //NOSONAR --><label asp-for="Status" class="form-label fw-bold text-dark"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<TodoTaskStatus>()" class="form-select border-2 fw-bold text-dark bg-light"></select>
            </div>
        </div>
        <div class="form-group mb-4 position-relative">
            <!-- //NOSONAR --><label asp-for="TagNames" class="form-label fw-bold text-dark"></label>
            <div class="input-group">
                <span class="input-group-text bg-white border-2 border-dark text-dark fw-bold"><i class="bi bi-hash"></i></span>
                <input asp-for="TagNames" id="TagNames" class="form-control border-2 fw-bold text-dark bg-light" autocomplete="off" />
            </div>
            <div id="tagSuggestions" class="list-group position-absolute w-100 border-2" style="z-index: 1000; display: none; top: 100%;"></div>
        </div>

        <partial name="_FormActions" model="@(("Create Task", "bi-check-lg", "btn-positive", Url.Action("Index", "TodoList")))" />
    </form>
</div>

@section Scripts {
    <script>window.allTags = @Html.Raw(Json.Serialize(ViewBag.AllTags ?? new List<string>()));</script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        await Html.RenderPartialAsync("_TagAutocomplete");
    }
}