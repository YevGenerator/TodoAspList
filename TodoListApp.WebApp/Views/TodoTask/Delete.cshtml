@model TodoListApp.WebApp.Models.TodoTaskModel

@{
    ViewData["Title"] = "Delete Task";
}

<div class="alert alert-danger" role="alert">
    <h4 class="alert-heading">Are you sure you want to delete this task?</h4>
    <p>This action cannot be undone.</p>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9 fw-bold">@Model.Title</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="todoListId" value="@Model.TodoListId" />
        <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
        <a asp-action="Index" asp-route-todoListId="@Model.TodoListId" class="btn btn-secondary">Cancel</a>
    </form>
</div>