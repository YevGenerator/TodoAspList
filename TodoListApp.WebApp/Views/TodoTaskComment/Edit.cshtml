@model TodoListApp.WebApp.Models.TodoTaskCommentModel
@{
    ViewData["Title"] = "Edit Comment";
}

<h2 class="fw-bold text-dark mb-4"><i class="bi bi-pencil text-primary me-2"></i>Edit Comment</h2>
<div class="card border-0 shadow-sm p-4 col-md-8">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="TodoTaskId" />

        <div class="form-group mb-3">
            <label asp-for="Text" class="form-label fw-bold text-dark"></label>
            <textarea asp-for="Text" class="form-control border-2 fw-bold text-dark bg-light" rows="4"></textarea>
            <span asp-validation-for="Text" class="text-danger fw-bold"></span>
        </div>

        <partial name="_FormActions" model="@(("Save Comment", "bi-save", "btn-positive", Url.Action("Details", "TodoTask", new { id = Model.TodoTaskId })))" />
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}