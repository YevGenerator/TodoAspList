@model TodoListApp.WebApp.Models.TodoTaskCommentModel

@{
    ViewData["Title"] = "Edit Comment";
}

<h2>Edit Comment</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TodoTaskId" />

            <div class="form-group mb-3">
                <label asp-for="Text" class="form-label fw-bold"></label>
                <textarea asp-for="Text" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success me-2">Save</button>
                <a asp-controller="TodoTask" asp-action="Details" asp-route-id="@Model.TodoTaskId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}