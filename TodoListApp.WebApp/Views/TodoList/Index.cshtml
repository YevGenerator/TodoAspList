@model IEnumerable<TodoListApp.WebApp.Models.TodoListModel>
@using TodoListApp.Models.Enums
@{
    ViewData["Title"] = "My To-Do Lists";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold text-dark"><i class="bi bi-list-task me-2 text-primary"></i>My To-Do Lists</h2>
    <a asp-action="Create" class="btn btn-positive"><i class="bi bi-plus-lg"></i> Create New List</a>
</div>

<div class="accordion" id="todoListsAccordion">
    @foreach (var list in Model)
    {
        <div class="accordion-item">
            <h2 class="accordion-header" id="heading-@list.Id">
                <button class="accordion-button collapsed fw-bold text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@list.Id" aria-expanded="false" aria-controls="collapse-@list.Id">
                    <span class="fs-5">@list.Title</span>
                    <span class="badge bg-primary text-white ms-3 rounded-pill px-3 shadow-sm">@list.Tasks.Count tasks</span>
                </button>
            </h2>
            <div id="collapse-@list.Id" class="accordion-collapse collapse" aria-labelledby="heading-@list.Id" data-bs-parent="#todoListsAccordion">
                <div class="accordion-body p-0">
                    <div class="d-flex justify-content-between align-items-center p-3 border-bottom border-light bg-white">
                        <span class="text-muted fw-bold">@list.Description</span>
                        <div class="d-flex gap-2">
                            <a asp-controller="TodoTask" asp-action="Index" asp-route-todoListId="@list.Id" class="btn btn-sm btn-positive"><i class="bi bi-box-arrow-up-right"></i> Open</a>
                            <a asp-action="Edit" asp-route-id="@list.Id" class="btn btn-sm btn-neutral"><i class="bi bi-pencil"></i> Edit</a>
                            <a asp-action="Delete" asp-route-id="@list.Id" class="btn btn-sm btn-negative"><i class="bi bi-trash"></i> Delete</a>
                        </div>
                    </div>
                    <div class="list-group list-group-flush p-3 bg-transparent">
                        @foreach (var task in list.Tasks.OrderBy(t => t.Status == TodoTaskStatus.Completed).ThenBy(t => t.DueDate))
                        {
                            <partial name="_TaskCard" model="@((task, "", User.Identity?.Name ?? "", "/TodoList", false, false))" />
                        }

                        <div class="px-2 mt-3 mb-1">
                            <a asp-controller="TodoTask" asp-action="Create" asp-route-todoListId="@list.Id" class="btn btn-positive w-100 py-3 rounded-3">
                                <i class="bi bi-plus-lg fs-5"></i> Add Task
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>