@model IEnumerable<TodoListApp.WebApp.Models.TodoListModel>

@{
    ViewData["Title"] = "My To-Do Lists";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My To-Do Lists</h2>
    <a asp-action="Create" class="btn btn-primary">Create New List</a>
</div>

<table class="table table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="3" class="text-center">You don't have any to-do lists yet.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle fw-bold">@item.Title</td>
                    <td class="align-middle">@item.Description</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>