@using TodoListApp.WebApp.Models
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    var overdueRaw = ViewBag.OverdueTasks as List<TodoListApp.Models.TodoTask> ?? new List<TodoListApp.Models.TodoTask>();
    var dueSoonRaw = ViewBag.DueSoonTasks as List<TodoListApp.Models.TodoTask> ?? new List<TodoListApp.Models.TodoTask>();
    var otherRaw = ViewBag.OtherTasks as List<TodoListApp.Models.TodoTask> ?? new List<TodoListApp.Models.TodoTask>();

    var overdueTasks = overdueRaw.Select(t => new TodoTaskModel { Id = t.Id, Title = t.Title, DueDate = t.DueDate, Status = t.Status, Assignee = t.Assignee, TodoListId = t.TodoListId, Tags = t.Tags.Select(tg => new TodoTagModel { Id = tg.Id, Name = tg.Name }).ToList() }).ToList();
    var dueSoonTasks = dueSoonRaw.Select(t => new TodoTaskModel { Id = t.Id, Title = t.Title, DueDate = t.DueDate, Status = t.Status, Assignee = t.Assignee, TodoListId = t.TodoListId, Tags = t.Tags.Select(tg => new TodoTagModel { Id = tg.Id, Name = tg.Name }).ToList() }).ToList();
    var otherTasks = otherRaw.Select(t => new TodoTaskModel { Id = t.Id, Title = t.Title, DueDate = t.DueDate, Status = t.Status, Assignee = t.Assignee, TodoListId = t.TodoListId, Tags = t.Tags.Select(tg => new TodoTagModel { Id = tg.Id, Name = tg.Name }).ToList() }).ToList();

    var listNames = ViewBag.ListNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    string userName = User.Identity.Name ?? "";

    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h2 class="fw-bold text-dark"><i class="bi bi-grid-1x2 me-2 text-primary"></i>Dashboard</h2>
        <div class="d-flex gap-2">
            <a asp-controller="TodoList" asp-action="Index" class="btn btn-neutral"><i class="bi bi-list-task"></i> My Lists</a>
            <a asp-controller="TodoTag" asp-action="Index" class="btn btn-neutral"><i class="bi bi-tags"></i> Manage Tags</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <partial name="_DashboardTaskList" model="@(("Overdue", "bi-exclamation-octagon", "danger", overdueTasks, listNames, userName))" />
            <partial name="_DashboardTaskList" model="@(("Due Soon", "bi-hourglass-split", "warning", dueSoonTasks, listNames, userName))" />
        </div>

        <div class="col-md-6 mb-4">
            <partial name="_DashboardTaskList" model="@(("Active Tasks", "bi-card-list", "primary", otherTasks, listNames, userName))" />
        </div>
    </div>
}
else
{
    <div class="text-center mt-5 pt-5">
        <h1 class="display-4 fw-bold text-dark mb-3"><i class="bi bi-check2-square text-primary"></i> To-Do App</h1>
        <p class="lead text-muted mb-4 fw-bold">Airy, colorful, and highly productive.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Account" asp-action="Register" class="btn btn-positive btn-lg"><i class="bi bi-person-plus"></i> Get Started</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-neutral btn-lg"><i class="bi bi-box-arrow-in-right"></i> Log In</a>
        </div>
    </div>
}