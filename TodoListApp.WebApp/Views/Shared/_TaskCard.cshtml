@model (TodoListApp.WebApp.Models.TodoTaskModel Task, string ListName, string CurrentUser, string ReturnUrl, bool ShowAssignee, bool ShowActions)

<button class="list-group-item task-row d-flex flex-column gap-2 p-3"
     onclick="window.location.href='@Url.Action("Details", "TodoTask", new { id = Model.Task.Id })'"
     tabindex="0">
    <div class="d-flex w-100 justify-content-between align-items-start">
        <span class="fw-bold text-dark fs-5 pe-3 @(Model.Task.Status == TodoListApp.Models.Enums.TodoTaskStatus.Completed ? "text-decoration-line-through text-muted opacity-50" : "")">@Model.Task.Title</span>
        <div class="d-flex gap-2 align-items-center">
            @if (Model.ShowActions)
            {
                 <!-- //NOSONAR --><a asp-controller="TodoTask" asp-action="Edit" asp-route-id="@Model.Task.Id" class="btn btn-sm btn-neutral py-1 px-2" onclick="event.stopPropagation()"><i class="bi bi-pencil"></i></a>
                 <!-- //NOSONAR --><a asp-controller="TodoTask" asp-action="Delete" asp-route-id="@Model.Task.Id" class="btn btn-sm btn-negative py-1 px-2" onclick="event.stopPropagation()"><i class="bi bi-trash"></i></a>
            }
            <partial name="_StatusForm" model="@((Model.Task.Id, Model.Task.Status, Model.CurrentUser, Model.ReturnUrl))" />
        </div>
    </div>

    <div class="d-flex align-items-center text-muted small fw-bold mt-1">
        <span class="me-3 text-nowrap"><i class="bi bi-calendar-event me-1"></i>@(Model.Task.DueDate?.ToShortDateString() ?? "No date")</span>

        @if (Model.ShowAssignee && !string.IsNullOrEmpty(Model.Task.Assignee))
        {
            <span class="me-3 text-nowrap"><i class="bi bi-person-badge me-1"></i>@Model.Task.Assignee</span>
        }

        @if (!string.IsNullOrEmpty(Model.ListName))
        {
            <span class="me-3 text-nowrap"><i class="bi bi-folder2-open me-1"></i>@Model.ListName</span>
        }

        @if (Model.Task.Tags != null && Model.Task.Tags.Any())
        {
            <div class="tags-container ms-auto border-start border-2 ps-3">
                @foreach (var tag in Model.Task.Tags)
                {
                    <partial name="_Tag" model="@tag.Name" />
                }
            </div>
        }
    </div>
</button>