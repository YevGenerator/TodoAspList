@model (string SubmitText, string SubmitIcon, string SubmitClass, string CancelUrl)

<div class="form-group mt-4 pt-3 border-top border-light d-flex gap-2">
    <button type="submit" class="btn @Model.SubmitClass px-4 py-2"><i class="bi @Model.SubmitIcon"></i> @Model.SubmitText</button>
    <a href="@Model.CancelUrl" class="btn btn-negative px-4 py-2"><i class="bi bi-x-lg"></i> Cancel</a>
</div>