@model (int TaskId, TodoListApp.Models.Enums.TodoTaskStatus Status, string Assignee, string ReturnUrl)
@using TodoListApp.Models.Enums
<form asp-controller="TodoTask" asp-action="ChangeStatus" method="post" class="d-flex m-0 w-100 justify-content-end">
    <input type="hidden" name="id" value="@Model.TaskId" />
    <input type="hidden" name="assignee" value="@Model.Assignee" />
    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
    <select name="newStatus" class="form-select form-select-sm status-select status-@Model.Status.ToString()" style="width: 140px;"
            onchange="this.form.submit()"
            onclick="event.stopPropagation()"
            onkeydown="if(event.key === 'Enter') event.stopPropagation()">
        @foreach (TodoTaskStatus stat in Enum.GetValues(typeof(TodoTaskStatus)))
        {
            <option value="@stat" selected="@(Model.Status == stat)">@stat</option>
        }
    </select>
</form>