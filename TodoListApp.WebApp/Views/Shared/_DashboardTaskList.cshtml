@model (string Title, string IconClass, string ColorScheme, List<TodoListApp.WebApp.Models.TodoTaskModel> Tasks, Dictionary<int, string> ListNames, string UserName)

<div class="card mb-4 frame-@Model.ColorScheme">
    <div class="card-header fw-bold d-flex justify-content-between align-items-center">
        <span><i class="@Model.IconClass me-2"></i>@Model.Title</span>
        <span class="badge bg-white text-dark border border-2 rounded-pill shadow-sm px-3">@Model.Tasks.Count</span>
    </div>
    <div class="list-group list-group-flush p-2 bg-transparent">
        @if (!Model.Tasks.Any())
        {
            <div class="p-3 text-center text-muted fw-bold">No tasks here.</div>
        }
        else
        {
            @foreach (var task in Model.Tasks)
            {
                <partial name="_TaskCard" model="@((task, Model.ListNames.GetValueOrDefault(task.TodoListId, "Unknown List"), Model.UserName, "/", false, false))" />
            }
        }
    </div>
</div>